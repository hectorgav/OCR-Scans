# ============================================================================
# --- PYTHON & BUILD ARTIFACTS ---
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
ENV/
env/

# ============================================================================
# --- IDE, OS & SECRETS ---
# ============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
.env
*.backup
*.bak
*.old

# ============================================================================
# --- PROJECT SPECIFIC: DATA & OUTPUTS (CRITICAL) ---
# ============================================================================
# Ignore all dynamically generated output (Images, Logs, and Local JSONs)
00-output/

# Ensure the directories exist for others, but stay empty in Git
!00-output/.gitkeep

# Ignore temporary text reports if any are still being generated
reports/
*.log

# ============================================================================
# --- PROJECT SPECIFIC: MACHINE LEARNING & MODELS ---
# ============================================================================
# Ignore heavy binary weights (Keep your .pt files local)
models/*.pt
models/*.pth
models/*.weights
models/*.onnx
runs/
weights/
checkpoints/

# ============================================================================
# --- PROJECT SPECIFIC: LOCAL TESTING ---
# ============================================================================
# Ignore your local ground truth files used for dev/testing
ground_truth/*.csv

# Optional: Ignore specific project notes or scratchpads
Project-Notes/

# Ignore files/folders with 'copy' in the name
# (Be careful: this ignores 'copyright' too!)
*copy*

# Ignore folders with 'superseded' in the name
**/*superseded*/

# Optional: Ignore common temporary editor files
*~
*.tmp