# ==========================================
# ENVIRONMENT & MODE SETTINGS
# ==========================================
# Options: OFFICE, HOME
WORK_ENV=HOME   

# Options: DEVELOPMENT, PRODUCTION
APP_MODE=DEVELOPMENT

# ==========================================
# HOME ENVIRONMENT PATHS (C: Drive)
# ==========================================
# Use forward slashes / to avoid escape character errors in Python
HOME_INPUT_PROD="C:/Users/USERNAME/Path/To/Production/Input"
HOME_OUTPUT_PROD="C:/Users/USERNAME/Path/To/Production/Output"

HOME_INPUT_DEV="C:/Users/USERNAME/Path/To/Development/Input"
HOME_OUTPUT_DEV="C:/Users/USERNAME/Path/To/Development/Output"

# ==========================================
# OFFICE ENVIRONMENT PATHS (G: Drive)
# ==========================================
OFFICE_INPUT_PROD="G:/Path/To/Office/Production/Input"
OFFICE_OUTPUT_PROD="G:/Path/To/Office/Production/Output"

OFFICE_INPUT_DEV="G:/Path/To/Office/Development/Input"
OFFICE_OUTPUT_DEV="G:/Path/To/Office/Development/Output"